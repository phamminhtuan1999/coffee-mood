# Secrets for local Edge Function development (`supabase functions serve
# ai-finder --env-file supabase/functions/.env`). Copy to `.env` in this
# directory and paste your key. This file's `.env` twin is gitignored.
#
# For the DEPLOYED function, set the secret in Supabase instead:
#   supabase secrets set GEMINI_API_KEY=your-key
# (or Dashboard → Edge Functions → Secrets)

GEMINI_API_KEY=
