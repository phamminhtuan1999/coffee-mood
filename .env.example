# CafeMood app environment (client-safe values ONLY — these are embedded in
# the app bundle). Copy to `.env` and fill in from your Supabase project:
# Dashboard → Project Settings → API. `.env` is gitignored.
#
# NEVER put the Gemini API key (or any provider secret) here — it belongs in
# Supabase function secrets. See supabase/README.md (decisions 0008/0021).
#
# Leave `.env` absent to run the app in demo mode (deterministic AI finder).

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
